{
  "name": "c_chat",
  "private": true,
  "description": "A chat application",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:apps": "turbo run dev --filter=@c_chat/service --filter=@c_chat/electron_client --filter=@c_chat/frontend --filter=@c_chat/media_preview",
    "dev:web": "turbo run dev --filter=@c_chat/service --filter=@c_chat/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check-types": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "setup:service": "node scripts/bootstrap-service-dev.mjs",
    "prepare": "husky install",
    "package": "turbo run package --filter=@c_chat/electron_client"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/types": "^20.4.3",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.2",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,html,css,scss}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
