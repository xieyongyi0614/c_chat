{
  "extends": "@c_chat/shared-config/baseTsConfig",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "paths": {
      "@c_chat/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@c_chat/shared-config": [
        "../../packages/shared-config/src/index.ts"
      ],
      "@c_chat/electron_client/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}